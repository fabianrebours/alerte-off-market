# ── Modelo / Netty ────────────────────────────────────────────────────
# Clé API Netty (header x-netty-api-key). Même clé que server-crm-immo.
MODELO_API_KEY=
MODELO_BASE_URL=https://webapi.netty.fr/apiv1

# ── Omni (entrepôt Matera : copros voisines + emails copropriétaires) ──
OMNI_API_KEY=
OMNI_URL=https://matera.omniapp.co
OMNI_MODEL_ID=225379a7-7597-48e1-a675-2777f3d42275

# ── Envoi depuis le Gmail de l'agent (canal prioritaire) ───────────────
# Expéditeur AFFICHÉ (From) de tous les mails — alias « Envoyer en tant que ».
EXPEDITEUR_NOM=Matera Transaction
EXPEDITEUR_EMAIL=transactions@matera.eu
# Compte Google qui s'authentifie (porteur du token), autorisé à envoyer avec
# l'alias ci-dessus. Vide = 1er compte connecté dans l'app (onglet Connexions).
COMPTE_ENVOI_EMAIL=

# OPTION RECOMMANDÉE — Délégation domaine (même orga matera.eu, zéro clic agent) :
# l'admin Workspace autorise un compte de service à envoyer comme tout @matera.eu.
# Fournir la clé JSON du compte de service (chemin OU JSON inline).
GOOGLE_SA_KEY_FILE=
GOOGLE_SA_KEY_JSON=

# OPTION 2 — Connexion individuelle (onglet Connexions) : token chiffré en local.
# GOOGLE_TOKEN_SECRET = clé hex 32 octets (64 hex). L'ID client OAuth doit autoriser
# l'URI {APP_BASE_URL}/oauth/google/callback + scope gmail.send (écran Interne).
GOOGLE_TOKEN_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optionnel : base CRM de PROD pour réutiliser les tokens déjà consentis côté CRM.
CRM_DATABASE_URL=

# ── Envoi email (Resend) — repli si l'agent n'a pas connecté son Google ─
RESEND_API_KEY=
RESEND_FROM_EMAIL=Matera Transaction <transactions@matera.eu>

# ── Application ─────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8787
PORT=8787

# Jeton d'accès à l'API (Bearer). Si défini, l'UI le demande au 1er accès (collé
# une fois, gardé dans le navigateur) et toute requête /api l'exige. Vide = API
# ouverte (dev local uniquement — NE PAS déployer sans jeton). Générer :
#   openssl rand -hex 32
FRONT_API_TOKEN=

# Base des landing pages par bien. Lien final : {base}/modelo-{product_ref}.html
LP_BASE_URL=https://s3.fr-par.scw.cloud/crm-immo-prod/lp

# Nombre de copropriétés voisines ciblées (+ la copro du bien si Matera → 6).
NB_COPROS_VOISINES=5

# Fenêtre de récence : on ne remonte que les biens créés depuis ≤ N jours.
RECENCE_JOURS=30

# Bac à sable : si =1, TOUS les envois sont redirigés vers TEST_RECIPIENT
# (rien ne part aux vrais copropriétaires). Mettre à 0 pour l'envoi réel.
ENVOI_SANDBOX=1
TEST_RECIPIENT=fabian.rebours@matera.eu
